# ── Whitelist: ignore everything at repo root except the app and README ──
/*
!/blog_summarizer/
!/README.md
!/.gitignore
!/Dockerfile
!/render.yaml
!/.dockerignore

# ── Junk rules (apply inside whitelisted folders too) ──

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
build/
dist/
wheels/
*.egg-info/
*.egg

# Database
*.db
*.sqlite3

# Environment / Secrets
.env
.venv
venv/
ENV/

# OS
.DS_Store
._*
Thumbs.db

# IDEs
.vscode/
.idea/

# Tooling artifacts
.vercel/
.pytest_cache/
graphify-out/
